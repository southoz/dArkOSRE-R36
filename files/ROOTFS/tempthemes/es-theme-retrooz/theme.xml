         <selectorColor>c547e8</selectorColor>
         <selectedColor>ffffff</selectedColor>
         <primaryColor>ffffff</primaryColor>
         <secondaryColor>8bfeff</secondaryColor>
         <fontPath>./_inc/fonts/bitcrusher condensed bd.ttf</fontPath>
         <fontSize>0.053</fontSize>
         <forceUppercase>1</forceUppercase>
         <scrollSound>./_inc/sounds/Move.wav</scrollSound>
         <zIndex>3</zIndex>
      </textlist>
   </view>
   <view name="detailed,video">
      <textlist name="gamelist">
         <pos>0.02 0.05</pos>
         <size>0.45 0.90</size>
         <alignment>left</alignment>
      </textlist>
   </view>
   <view name="basic">
      <textlist name="gamelist">
         <pos>0.2 0.25</pos>
         <size>.6 0.7</size>
         <alignment>center</alignment>
      </textlist>
   </view>
   <view name="basic">
