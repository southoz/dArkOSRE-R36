   <view name="menu">
      <menuText name="menutitle">
         <color>FFFFFFFF</color>
      </menuText>
      <menuText name="menutext">
         <fontSize>.045</fontSize>
         <color>FFFFFFFF</color>>
         <selectorColor>FFFFFFFF</selectorColor>>
         <selectorColorEnd>FFFFFFFF</selectorColorEnd>
         <selectedColor>000000</selectedColor>
