<?xml version="1.0" encoding="UTF-8"?>
<theme>
   <formatVersion>4</formatVersion>
   <feature supported="carousel">
      <view name="system">
         <carousel name="systemcarousel">
            <type>vertical</type>
            <pos>0.0 -0.025</pos>
            <logoAlignment>middle</logoAlignment>
            <size>1 1</size>
            <logoScale>5.0</logoScale>
            <zIndex>3</zIndex>
            <logoSize>0.2 0.14</logoSize>
            <color>00000000</color>
            <maxLogoCount>1</maxLogoCount>
         </carousel>
         <image name="background" extra="true">
            <origin>0 0</origin>
            <pos>0 0</pos>
            <size>1 1</size>
            <zIndex>2</zIndex>
            <path>./_inc/images/background.png</path>
         </image>
         <text name="systemInfo">
            <pos>0.0 0.8</pos>
            <backgroundColor>00000000</backgroundColor>
            <color>ffffff</color>
            <fontPath>./_inc/fonts/Cabin-Bold.ttf</fontPath>
            <fontSize>0.048</fontSize>
            <zIndex>5</zIndex>
         </text>
      </view>
   </feature>
   <view name="system">
      <helpsystem name="help">
         <fontPath>./_inc/fonts/Cabin-Bold.ttf</fontPath>
         <fontSize>0.03</fontSize>
         <pos>0.515 0.955</pos>
         <origin>0.5 0.5</origin>
         <textColor>ffffff</textColor>
         <iconColor>ffffff</iconColor>
      </helpsystem>
   </view>
   <view name="detailed,video,basic">
